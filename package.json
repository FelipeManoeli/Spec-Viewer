{
  "name": "spec-viewer-workspace",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "workspaces": [
    "packages/*",
    "cli"
  ],
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --build --force",
    "clean": "rm -rf packages/*/dist cli/dist packages/*/tsconfig.tsbuildinfo cli/tsconfig.tsbuildinfo"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
