#!/usr/bin/env bash
# spec-viewer setup
#
# - Verifies Node >= 20 + npm
# - Installs npm deps + builds the TypeScript sources
# - Auto-installs Playwright + chromium (~300MB, ~1 min) so /spec-capture
#   works on first invocation. Skip with --skip-browser if you only need
#   /spec-init + /spec-build.
# - Creates the bin/spec-viewer wrapper Claude invokes
# - Registers each skill at ~/.claude/skills/<name>/SKILL.md (the path
#   Claude Code actually discovers)
#
# Idempotent: safe to re-run after `git pull`.

set -euo pipefail

INSTALL_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILLS_DIR="${SPEC_VIEWER_SKILLS_DIR:-$HOME/.claude/skills}"

SKIP_BROWSER=0
for arg in "$@"; do
  case "$arg" in
    --skip-browser) SKIP_BROWSER=1 ;;
    --help|-h)
      cat <<'USAGE'
Usage: ./setup [--skip-browser]

  --skip-browser  Don't auto-install Playwright chromium. Run later with
                  `npx playwright install chromium` if you want /spec-capture.
USAGE
      exit 0
      ;;
  esac
done

# ── Preflight ─────────────────────────────────────────────────────────────────
NODE_VER=$(node -v 2>/dev/null || echo "v0")
NODE_MAJOR=$(echo "$NODE_VER" | sed 's/^v//;s/\..*//')
if [ "$NODE_MAJOR" -lt 20 ] 2>/dev/null; then
  echo "✗ Node >= 20 required (found: $NODE_VER)" >&2
  echo "  Install via your package manager or https://nodejs.org/" >&2
  exit 1
fi
command -v npm >/dev/null 2>&1 || { echo "✗ npm not found on PATH" >&2; exit 1; }

echo "spec-viewer setup"
echo "  Source: $INSTALL_DIR"
echo "  Skills: $SKILLS_DIR"
echo "  Node:   $NODE_VER"
echo

# ── Install + build ──────────────────────────────────────────────────────────
cd "$INSTALL_DIR"
echo "▸ Installing npm dependencies..."
npm install --silent --no-audit --no-fund

echo "▸ Building TypeScript projects..."
npm run -s build

# ── Playwright + chromium ────────────────────────────────────────────────────
# Same approach as gstack's setup: install chromium during ./setup so the
# user never hits "browser missing" during their first /spec-capture. Plays
# nicely with `git pull && ./setup` — the install is idempotent.
ensure_chromium() {
  node -e "const p=require('playwright').chromium; const fs=require('fs'); const x=p.executablePath(); if(!fs.existsSync(x)) process.exit(1); console.log(x)" 2>/dev/null
}

if [ "$SKIP_BROWSER" -eq 1 ]; then
  echo "▸ Skipping Playwright chromium install (--skip-browser)"
  echo "  Run later with: npx playwright install chromium"
elif ensure_chromium >/dev/null; then
  echo "▸ Playwright chromium already installed"
else
  echo "▸ Installing Playwright chromium (~300MB, ~1 min)..."
  if npx --yes playwright install chromium 2>&1 | tail -3; then
    if ensure_chromium >/dev/null; then
      echo "  ✓ chromium ready"
    else
      echo "  ! chromium install reported success but binary not found; capture may fail" >&2
      echo "    Run manually: npx playwright install chromium" >&2
    fi
  else
    echo "  ! chromium install failed; /spec-capture will not work until you run" >&2
    echo "    npx playwright install chromium" >&2
  fi
fi

# ── Binary shim ──────────────────────────────────────────────────────────────
mkdir -p "$INSTALL_DIR/bin"
SHIM="$INSTALL_DIR/bin/spec-viewer"
cat > "$SHIM" <<'EOF'
#!/usr/bin/env bash
DIR="$(cd "$(dirname "$0")" && pwd)"
exec node "$DIR/../cli/dist/bin.js" "$@"
EOF
chmod +x "$SHIM"

# Self-check
"$SHIM" --version >/dev/null 2>&1 || {
  echo "✗ Binary self-check failed. Try 'npm run build' and re-run ./setup." >&2
  exit 1
}

# ── Register skills ──────────────────────────────────────────────────────────
mkdir -p "$SKILLS_DIR"
echo
echo "▸ Registering skills in $SKILLS_DIR:"
for skill_md in "$INSTALL_DIR"/spec-*/SKILL.md; do
  [ -f "$skill_md" ] || continue
  name=$(basename "$(dirname "$skill_md")")
  mkdir -p "$SKILLS_DIR/$name"
  ln -sfn "$skill_md" "$SKILLS_DIR/$name/SKILL.md"
  echo "  /$name"
done

# ── Done ─────────────────────────────────────────────────────────────────────
echo
echo "✓ Setup complete"
echo
echo "Test the install:"
echo "  $SHIM doctor"
echo
echo "Use in any project:"
echo "  /spec-init       scaffold config + branding"
echo "  /spec-theme      tweak colors anytime"
echo "  /spec-capture    screenshot a running app"
echo "  /spec-build      render the viewer"
echo
echo "If skills don't appear in Claude Code, restart the session."
